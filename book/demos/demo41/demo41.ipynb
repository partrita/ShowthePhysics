   ],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "g = 9.8 #m/s2\n",
    "A_top = 50 #cm2\n",
    "H_0 = 20 #cm\n",
    "\n",
    "A_tube = 1 #cm2\n",
    "L_tube_1 = 5 #cm\n",
    "L_tube_2 = 10 #cm\n",
    "\n",
    "h1 = []\n",
    "h1.append(H_0)\n",
    "h2 = []\n",
    "h2.append(H_0)\n",
    "t = []\n",
    "t.append(0)\n",
    "dt = 1 #s\n",
    "v1 = []\n",
    "v2 = []\n",
    "i = 0\n",
    "\n",
    "while min(h1[i],h2[i])>0:\n",
    "    v1.append(np.sqrt(2*g*(h1[i]+L_tube_1)))\n",
    "    v2.append(np.sqrt(2*g*(h2[i]+L_tube_2)))\n",
    "               \n",
    "    Q1 = A_tube * v1[i] * dt\n",
    "    Q2 = A_tube * v2[i] * dt\n",
    "\n",
    "    h1.append(h1[i] - Q1 / A_top * dt)\n",
    "    h2.append(h2[i] - Q2 / A_top * dt)\n",
    "              \n",
    "    t.append(t[i] + dt)\n",
    "    i += 1\n",
    "\n",
    "# 시뮬레이션 플로팅\n",
    "plt.figure( )\n",
    "plt.plot(t, h1, 'k.', label='짧은 튜브')\n",
    "plt.plot(t, h2, 'r.', label='긴 튜브')\n",
    "\n",
    "plt.xlabel('시간 (s)')\n",
    "plt.ylabel('높이 (cm)')\n",
    "plt.legend()\n",
    "plt.show()\n"
   ]
  },

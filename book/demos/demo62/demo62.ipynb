     "name": "stdout",
     "output_type": "stream",
     "text": [
      "물속에서의 빛의 속도는: 2.997025469999997 *10^8 m/s\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "# 단일 측정을 통한 물속 빛의 속도 결정\n",
    "\n",
    "# 상수\n",
    "c_air = 299702547 # m/s, 공기 중 빛의 속도\n",
    "\n",
    "# 측정값 (단위: 미터)\n",
    "s2 = 0.29\n",
    "s3 = 0.01\n",
    "s4 = 0.3\n",
    "\n",
    "# 계산\n",
    "t_water = s4/c_air - s2/c_air\n",
    "c_water = s3/t_water\n",
    "\n",
    "# 결과 출력\n",
    "print(\"물속에서의 빛의 속도는:\", c_water*1e-8, \"*10^8 m/s\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Python 데이터 분석 예시\n",
    "아래 코드 셀은 노르베르트 반 빈(Norbert van Veen)이 수집한 측정값 일부를 사용한 전체 데이터 분석을 보여줍니다. 측정값 중 하나(예: 물 없이 측정한 거리)에 작은 측정 오차가 있을 수 있음을 고려하여 계통 오차를 도입했습니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {
    "tags": [
     "init"
    ]
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "계통 오차는: -0.0007806756712641851\n",
      "계산된 값은: 232127024.99422067\n"
     ]
    },
    {
     "data": {
      "image/png": "... [truncated]
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "물속에서의 빛의 속도는: 2.3 +/- 0.2 *10^8 m/s\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.optimize import curve_fit\n",
    "\n",
    "# 여러 측정값을 사용한 예시\n",
    "\n",
    "# 상수\n",
    "c_air = 299702547 # m/s, 공기 중 빛의 속도\n",
    "\n",
    "# 측정값 (단위: 미터)\n",
    "s1 = np.array([30,30,60.2,60.2,60.2,60.2,30,30,40,40,40,40,65.1,66])*1e-2\n",
    "s4 = np.array([30.2,30.5,61.2,61.8,62.8,63.85,31.1,31.8,40.1,40.4,41.3,41.9,67.4,68])*1e-2\n",
    "s2 = np.array([29,28,53.5,52.5,51.5,57.3,26,24,39,38,36,34,60,57.7])*1e-2\n",
    "\n",
    "# 계산\n",
    "s3 = s1 - s2\n",
    "t_water = (s4-s2)/c_air\n",
    "c_water = s3/t_water\n",
    "\n",
    "# c_water 배열을 확인하려면 아래 주석을 해제하십시오.\n",
    "# print(c_water)\n",
    "\n",
    "# curve_fit을 사용하여 물속 빛의 속도와 잠재적인 계통 오차를 찾음\n",
    "def c_w(t,c_w,sys_err):\n",
    "    return c_w*t + sys_err\n",
    "\n",
    "var, cov = curve_fit(c_w,t_water,s3)\n",
    "\n",
    "# curve fit 결과 출력\n",
    "print('계통 오차는:', var[1]) \n",
    "print('계산된 값은:', var[0]) \n",
    "\n",
    "\n",
    "# 피팅된 값과 측정값을 플로팅하기 위해 배열 정의\n",
    "x_test = np.linspace(min(t_water),max(t_water),1000)\n",
    "y_test = c_w(x_test,*var)\n",
    "\n",
    "# 수심 대 t_water 그래프\n",
    "plt.figure()\n",
    "\n",
    "plt.plot(s3,t_water,'k.')\n",
    "plt.plot(y_test,x_test,'r--')\n",
    "\n",
    "plt.xlabel('$waterdepth$ (m)')\n",
    "plt.ylabel('$t_{water}$ (s)')\n",
    "plt.grid()\n",
    "\n",
    "plt.show()\n",
    "\n",
    "print('물속에서의 빛의 속도는:',round(var[0]*1e-8,1),'+/-',round(np.sqrt(cov[0,0])*1e-8,1),'*10^8 m/s')"
   ]
  },
